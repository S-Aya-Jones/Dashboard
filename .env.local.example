# Neon Postgres connection string
# Get this from your Neon dashboard at console.neon.tech
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Anthropic API key — used for AI recipe extraction from screenshots
# Get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps API key — enables embedded interactive route maps on the
# Exposure Therapy page (Maps Embed API). Create a project at
# console.cloud.google.com, enable "Maps Embed API", create an API key,
# and restrict it to your domain. Billing must be enabled on the project
# (Google gives a free monthly credit that easily covers personal use).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
